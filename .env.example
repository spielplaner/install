# © Frank-Christian Struve 2026 · Version 26 R3
# SpielPlaner — End-User-Installer (.env-Template)
# Generiert aus spielplaner/.env.example. NICHT von Hand bearbeiten.
# install.sh ueberschreibt Tech-Werte beim Erstlauf interaktiv.

# Image-Pin (ADR-0002 E3): konkrete Version statt :latest fuer Reproduzierbarkeit.
# Update = bewusster Edit hier + 'docker compose pull && ./install.sh'.
IMAGE_TAG=v0.6.0

# © Frank-Christian Struve 2026 · Version 26 rev 0.1
# SpielPlaner — Environment Variables (Template)
# Copy to .env and fill in real values. NEVER commit .env.

# --- General ---
ENVIRONMENT=development           # development | staging | production
LOG_LEVEL=INFO
TZ=Europe/Berlin

# --- Domain & HTTPS ---
PUBLIC_BASE_URL=https://spielplaner.insel.theater
API_BASE_URL=http://api:8000
WEB_BASE_URL=http://web:3000

# --- Database (MariaDB 11) ---
MYSQL_ROOT_PASSWORD=change-me-root
MYSQL_DATABASE=spielplaner
MYSQL_USER=spielplaner
MYSQL_PASSWORD=change-me-app
DB_HOST=db
DB_PORT=3306
DATABASE_URL=mysql+asyncmy://spielplaner:change-me-app@db:3306/spielplaner?charset=utf8mb4

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# --- Auth / JWT ---
JWT_SECRET=generate-with-openssl-rand-hex-32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_MINUTES=15
REFRESH_TOKEN_DAYS=14
ARGON2_MIN_PASSWORD_LEN=12
LOCKOUT_THRESHOLD=5
LOCKOUT_WINDOW_MIN=15

# --- OIDC-Provider (later) ---
OIDC_ISSUER=https://spielplaner.insel.theater

# --- Admin-Bootstrap (used by install.sh once) ---
BOOTSTRAP_ADMIN_EMAIL=admin@insel.theater
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=change-me-at-first-login

# --- PDF-Render (Sprint G 2026-05-02) ---
# HTML→PDF: WeasyPrint inhouse im API-Container, keine Settings noetig.
# DOCX→PDF: schlanke loffice-Sidecar (libreoffice-headless).
LIBREOFFICE_URL=http://loffice:2004

# --- Uploads (Gesundheitszeugnis etc.) ---
UPLOADS_DIR=/app/uploads          # Container-Pfad; ist via DATA_ROOT/uploads persistent
MAX_UPLOAD_MB=10

# --- Reminder-Cron ---
# Shared secret für NAS-Cron → POST /api/v1/tasks/send-reminders (Header X-Cron-Token).
# Leer = Endpoint nur via Admin-JWT.
REMINDER_CRON_TOKEN=generate-with-openssl-rand-hex-24
REMINDER_LOOKAHEAD_DAYS=3

# --- Mail (IMAP/SMTP) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@insel.theater
SMTP_TLS=true

# --- Sentry (Error-Tracking, R2-Hotfix RH-7) ---
# Leer = deaktiviert (Dev-Default). In Prod DSN aus sentry.io eintragen.
SENTRY_DSN=
SENTRY_ENVIRONMENT=                # leer = uebernimmt ENVIRONMENT
SENTRY_TRACES_SAMPLE_RATE=0.0      # 0 = nur Errors, 0.1 = 10% APM-Traces
SENTRY_RELEASE=                    # leer = auto aus __version__

# --- KI ---
AI_ENABLED=false
ANTHROPIC_API_KEY=
AI_MODEL_DEFAULT=claude-sonnet-4-6
AI_MONTHLY_BUDGET_EUR=20

# --- Backup ---
BACKUP_DIR=/volume1/backups/spielplaner
BACKUP_RETENTION_DAILY=30
BACKUP_RETENTION_WEEKLY=12
BACKUP_RETENTION_MONTHLY=12

# --- Synology Volume-Root ---
DATA_ROOT=./data                  # production: /volume1/docker/spielplaner
PUID=1026
PGID=100

# --- Multi-Tenant ---
# Slug, der WebPlaner sagt, welches Theater er rendert.
# Default: feinfein. Pro Installation einmal setzen.
# WICHTIG: Compose's --env-file parser nimmt INLINE-Kommentare in den Wert
# auf — daher hier KEINE  '# ...'-Kommentare hinter dem '='.
PUBLIC_TENANT_SLUG=feinfein

# --- WebPlaner (oeffentliche Theater-Website) ---
# Aktivierung des Services via:  docker compose --profile webplaner up -d
# install.sh setzt ENABLE_WEBPLANER und nimmt es in COMPOSE_PROFILES auf.
# 0 = aus, 1 = an
ENABLE_WEBPLANER=0
# interne Container-zu-Container-URL
WEBPLANER_API_BASE=http://api:8000
# extern; mit Traefik: install.sh ueberschreibt auf https://<domain>
WEBPLANER_PUBLIC_URL=http://localhost:3001
# 1 = "DEV"-Hinweis im Header
WEBPLANER_DEV_BANNER=0

# --- TLS / Reverse-Proxy ---
# extern  = Synology Application Portal o.ae. terminiert TLS, Traefik laeuft nicht
# traefik = Traefik-Sidecar im Stack uebernimmt Routing + Lets-Encrypt
TLS_MODE=extern
# wird von install.sh auf 'true' gesetzt, wenn TLS_MODE=traefik
TRAEFIK_ENABLE=false
# Domains werden von install.sh interaktiv abgefragt (nur bei TLS_MODE=traefik)
TRAEFIK_DOMAIN_API=
TRAEFIK_DOMAIN_WEB=
TRAEFIK_DOMAIN_WEBPLANER=
# Mail fuer Lets-Encrypt-Cert-Anfrage
TRAEFIK_LE_EMAIL=
